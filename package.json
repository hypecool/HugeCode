{
  "name": "hugecode-workspace",
  "private": true,
  "workspaces": [
    "apps/code",
    "apps/code-web",
    "apps/code-tauri",
    "packages/*",
    "tests/*"
  ],
  "type": "module",
  "scripts": {
    "workflow:list": "node scripts/workflow-list.mjs",
    "tokens:build": "pnpm --filter @ku0/design-system tokens:build",
    "tokens:check": "pnpm --filter @ku0/design-system tokens:check",
    "check:repo:sot": "node scripts/check-repo-sot.mjs",
    "check:workflow-governance": "node scripts/check-workflow-governance.mjs",
    "check:workspace-task-coverage": "node scripts/check-workspace-task-coverage.mjs",
    "check:branch-policy": "node scripts/check-branch-policy.mjs",
    "repo:doctor": "node scripts/check-repo-sot.mjs && node scripts/check-workflow-governance.mjs && node scripts/diagnose-project.mjs && pnpm preflight:codex",
    "repo:doctor:strict": "node scripts/check-repo-sot.mjs && node scripts/check-workflow-governance.mjs && node scripts/diagnose-project.mjs --strict --fetch && pnpm preflight:codex",
    "dev": "pnpm dev:code",
    "dev:code": "pnpm dev:code:runtime-gateway-web:all",
    "web:dev": "pnpm --filter @ku0/code-web run dev",
    "web:build": "pnpm --filter @ku0/code-web run build",
    "web:preview": "pnpm --filter @ku0/code-web run preview",
    "web:deploy": "pnpm --filter @ku0/code-web run deploy",
    "web:typecheck": "pnpm --filter @ku0/code-web run typecheck",
    "experimental:web:dev": "pnpm web:dev",
    "experimental:web:build": "pnpm web:build",
    "experimental:web:typecheck": "pnpm web:typecheck",
    "dev:code:ui": "turbo run dev --filter=@ku0/code",
    "dev:code:service": "node scripts/dev-code-runtime-service.mjs",
    "dev:code:runtime-gateway-web": "node scripts/dev-code-runtime-gateway-web.mjs",
    "dev:code:runtime-gateway-web:all": "node scripts/dev-code-runtime-gateway-web-all.mjs",
    "dev:desktop": "pnpm --filter @ku0/code-tauri run dev",
    "desktop:prepare": "node scripts/desktop-prebuild.mjs",
    "desktop:prepare:fast": "node scripts/desktop-prebuild.mjs --mode fast",
    "desktop:prepare:full": "node scripts/desktop-prebuild.mjs --mode full",
    "desktop:prepare:skip": "node scripts/desktop-prebuild.mjs --mode skip",
    "desktop:verify:fast": "pnpm check:desktop-capabilities && turbo run check --filter=@ku0/code-tauri",
    "desktop:verify": "pnpm check:desktop-capabilities && pnpm test:desktop:smoke && pnpm --filter @ku0/code-tauri run build -- --debug --no-bundle",
    "desktop:verify:mac:intel": "pnpm check:desktop-capabilities && pnpm --filter @ku0/code-tauri run build -- --target x86_64-apple-darwin --debug --no-bundle",
    "desktop:verify:mac:apple": "pnpm check:desktop-capabilities && pnpm --filter @ku0/code-tauri run build -- --target aarch64-apple-darwin --debug --no-bundle",
    "desktop:doctor:windows": "node scripts/check-windows-host.mjs --target x86_64-pc-windows-msvc",
    "desktop:doctor:windows:arm64": "node scripts/check-windows-host.mjs --target aarch64-pc-windows-msvc",
    "desktop:verify:windows": "pnpm desktop:doctor:windows && pnpm check:desktop-capabilities && pnpm --filter @ku0/code-tauri run build -- --target x86_64-pc-windows-msvc --debug --no-bundle",
    "desktop:verify:windows:arm64": "pnpm desktop:doctor:windows:arm64 && pnpm check:desktop-capabilities && pnpm --filter @ku0/code-tauri run build -- --target aarch64-pc-windows-msvc --debug --no-bundle",
    "desktop:verify:linux": "pnpm check:desktop-capabilities && pnpm --filter @ku0/code-tauri run build -- --target x86_64-unknown-linux-gnu --debug --no-bundle",
    "desktop:verify:linux:arm64": "pnpm check:desktop-capabilities && pnpm --filter @ku0/code-tauri run build -- --target aarch64-unknown-linux-gnu --debug --no-bundle",
    "desktop:build": "pnpm --filter @ku0/code-tauri run build",
    "desktop:build:mac:intel": "pnpm --filter @ku0/code-tauri run build -- --target x86_64-apple-darwin --bundles dmg",
    "desktop:build:mac:apple": "pnpm --filter @ku0/code-tauri run build -- --target aarch64-apple-darwin --bundles dmg",
    "desktop:build:mac:universal": "pnpm --filter @ku0/code-tauri run build -- --target universal-apple-darwin --bundles dmg",
    "desktop:build:windows": "pnpm desktop:doctor:windows && pnpm --filter @ku0/code-tauri run build -- --target x86_64-pc-windows-msvc --bundles nsis",
    "desktop:build:windows:msi": "pnpm desktop:doctor:windows && pnpm --filter @ku0/code-tauri run build -- --target x86_64-pc-windows-msvc --bundles msi",
    "desktop:build:windows:all": "pnpm desktop:doctor:windows && pnpm --filter @ku0/code-tauri run build -- --target x86_64-pc-windows-msvc --bundles nsis,msi",
    "desktop:build:windows:store": "pnpm desktop:doctor:windows && pnpm --filter @ku0/code-tauri run build -- --target x86_64-pc-windows-msvc --bundles nsis --config src-tauri/tauri.windows.store.conf.json",
    "desktop:build:windows:arm64": "pnpm desktop:doctor:windows:arm64 && pnpm --filter @ku0/code-tauri run build -- --target aarch64-pc-windows-msvc --bundles nsis",
    "desktop:build:windows:arm64:store": "pnpm desktop:doctor:windows:arm64 && pnpm --filter @ku0/code-tauri run build -- --target aarch64-pc-windows-msvc --bundles nsis --config src-tauri/tauri.windows.store.conf.json",
    "desktop:build:linux": "pnpm --filter @ku0/code-tauri run build -- --target x86_64-unknown-linux-gnu --bundles deb,appimage",
    "desktop:build:linux:arm64": "pnpm --filter @ku0/code-tauri run build -- --target aarch64-unknown-linux-gnu --bundles deb,appimage",
    "code:build": "pnpm -C apps/code build",
    "report:code:bundle": "node scripts/report-code-bundle.mjs",
    "check:code:bundle-budget": "node scripts/check-code-bundle-budget.mjs",
    "check:code-web:bundle-budget": "node scripts/check-code-bundle-budget.mjs --assets-dir apps/code-web/dist/open_fast_web/assets --config scripts/config/code-web-bundle-budget.config.mjs",
    "build": "turbo run build",
    "build:affected": "node scripts/run-turbo-affected.mjs build",
    "test": "pnpm test:unit",
    "test:unit": "pnpm check:test-placeholders && node scripts/run-unit-tests.mjs",
    "test:unit:ci": "pnpm check:test-placeholders && node scripts/run-unit-tests.mjs --coverage",
    "test:watch": "vitest",
    "test:component": "pnpm check:test-placeholders && vitest run --config apps/code/vitest.browser.config.ts",
    "test:component:watch": "vitest --config apps/code/vitest.browser.config.ts",
    "test:affected": "node scripts/run-turbo-affected.mjs test",
    "test:related": "node scripts/validate.mjs --targeted-only --skip-lint --skip-typecheck",
    "test:project:packages-default": "vitest run --config vitest.root.config.ts",
    "test:runtime:review-pack-selection": "vitest run --config vitest.root.config.ts tests/scripts/review-pack-selection-flow.test.ts",
    "test:contract": "pnpm --filter @ku0/code-runtime-host-contract test && pnpm --filter @ku0/native-runtime-host-contract test && pnpm check:runtime-contract",
    "test:desktop:smoke": "node scripts/run-cargo-with-target-guard.mjs --cwd apps/code-tauri test --manifest-path src-tauri/Cargo.toml desktop_smoke_",
    "test:e2e": "pnpm --filter @ku0/e2e-tests test:e2e",
    "test:e2e:core": "node scripts/run-e2e-category.mjs core",
    "test:e2e:blocks": "node scripts/run-e2e-category.mjs blocks",
    "test:e2e:collab": "node scripts/run-e2e-category.mjs collab",
    "test:e2e:annotations": "node scripts/run-e2e-category.mjs annotations",
    "test:e2e:features": "node scripts/run-e2e-category.mjs features",
    "test:e2e:smoke": "node scripts/run-e2e-category.mjs smoke",
    "test:e2e:a11y": "node scripts/run-e2e-category.mjs a11y",
    "test:e2e:ux-audit": "node tests/e2e/scripts/core-ux-audit.mjs",
    "runtime:prove": "pnpm -C internal/runtime-proving runtime:prove",
    "debug:web:mcp": "playwright-mcp",
    "test:worker:quick": "pnpm -C apps/code test:worker:quick",
    "test:pr": "pnpm test:affected",
    "test:ci": "pnpm test:unit:ci",
    "perf:gate": "node scripts/perf-gate.mjs --baseline artifacts/perf-baseline.json --metrics artifacts/perf-metrics.json",
    "lint": "turbo run lint && oxlint . && pnpm lint:styles",
    "lint:affected": "node scripts/run-turbo-affected.mjs lint",
    "lint:fix": "oxlint --fix --fix-suggestions .",
    "lint:styles": "node scripts/check-inline-styles.mjs && node scripts/check-style-stack.mjs && node scripts/check-style-color-sot.mjs --all && node scripts/check-style-semantic-primitives.mjs --all && node scripts/check-style-compat-boundary.mjs",
    "check:style-color-sot": "node scripts/check-style-color-sot.mjs --all",
    "check:style-semantic-primitives": "node scripts/check-style-semantic-primitives.mjs --all",
    "check:style-compat-boundary": "node scripts/check-style-compat-boundary.mjs",
    "check:style-stack": "node scripts/check-style-stack.mjs",
    "check:design-system:exports": "node scripts/check-design-system-barrels.mjs",
    "check:design-system:app-imports": "node scripts/check-code-ui-imports.mjs",
    "check:design-system:legacy-token-deps": "node scripts/check-design-system-legacy-token-deps.mjs",
    "check:design-system:surface-semantics": "node scripts/check-design-system-surface-semantics.mjs",
    "check:design-system:storybook-coverage": "node scripts/check-design-system-storybook-coverage.mjs",
    "check:design-system:family-contracts": "node scripts/check-design-system-family-contracts.mjs",
    "check:design-system:family-adoption": "node scripts/check-design-system-family-adoption.mjs",
    "check:design-system:governance-fixture-coverage": "node scripts/check-design-system-governance-fixture-coverage.mjs",
    "check:design-system:operator-adjunct-fixture-coverage": "node scripts/check-design-system-operator-adjunct-fixture-coverage.mjs",
    "check:design-system:fixture-smoke": "node scripts/run-design-system-fixture-smoke.mjs",
    "check:design-system:baseline": "pnpm check:design-system:exports && pnpm check:design-system-ownership && pnpm check:design-system:surface-semantics && pnpm check:design-system:app-imports && pnpm check:design-system:legacy-token-deps && pnpm check:design-system:storybook-coverage && pnpm check:design-system:family-contracts && pnpm check:design-system:family-adoption && pnpm check:design-system:governance-fixture-coverage && pnpm check:design-system:operator-adjunct-fixture-coverage && node scripts/check-style-compat-boundary.mjs && pnpm check:design-system:fixture-smoke",
    "docs:normative-index": "node scripts/update-normative-index.mjs",
    "roadmap:new-track": "tsx scripts/roadmap/create-track.ts",
    "ui:contract": "node scripts/check-ui-service-boundary.mjs && node scripts/check-app-source-boundary.mjs",
    "check:rust-file-size": "node scripts/check-rust-file-size.mjs",
    "check:runtime-layering": "node scripts/check-runtime-layering.mjs",
    "check:turbo-boundaries": "node scripts/check-turbo-boundaries.mjs",
    "check:runtime-port-exports": "node scripts/check-runtime-port-exports.mjs",
    "check:app-source-boundary": "node scripts/check-app-source-boundary.mjs",
    "check:runtime-contract": "pnpm --filter @ku0/code-runtime-host-contract spec:check && pnpm check:runtime-sot",
    "check:runtime-contract:parity": "node scripts/check-runtime-contract-parity.mjs",
    "check:desktop-capabilities": "node scripts/check-desktop-capabilities.mjs",
    "check:no-wildcard-exports": "node scripts/check-no-wildcard-exports.mjs",
    "check:runtime-sot": "node scripts/check-runtime-sot.mjs",
    "check:design-runtime-sot": "node scripts/check-design-runtime-sot.mjs",
    "check:feature-style-islands": "node scripts/check-feature-style-islands.mjs",
    "check:design-system-ownership": "node scripts/check-design-system-ownership.mjs",
    "check:llm-scaffolding": "node scripts/check-llm-scaffolding.mjs",
    "check:test-placeholders": "node scripts/check-test-placeholders.mjs",
    "check:runtime-tool-success-rate": "node scripts/check-runtime-tool-success-rate.mjs --expected-window-size 500",
    "check:runtime-tool-reliability": "node scripts/check-runtime-tool-reliability.mjs --expected-window-size 500",
    "runtime:tool-metrics:probe": "node scripts/collect-runtime-tool-metrics.mjs --probe",
    "runtime:tool-metrics:collect": "node scripts/collect-runtime-tool-metrics.mjs",
    "runtime:tool-metrics:reset": "node scripts/collect-runtime-tool-metrics.mjs --reset",
    "runtime:tool-metrics:gate:probe": "pnpm run runtime:tool-metrics:reset && pnpm run runtime:tool-metrics:probe && pnpm run runtime:tool-metrics:collect && pnpm run check:runtime-tool-success-rate -- --min-success-rate 0.95",
    "check:ui-service-boundary": "node scripts/check-ui-service-boundary.mjs",
    "check:app-circular": "madge apps/code/src --extensions ts,tsx --circular",
    "check:frontend-file-size": "node scripts/check-frontend-file-size.mjs",
    "check:frontend-file-size:all": "node scripts/check-frontend-file-size.mjs --all",
    "check:style-boundary:all": "node scripts/check-global-style-boundary.mjs --all && node scripts/check-duplicate-global-selectors.mjs --all && node scripts/check-stale-style-selectors.mjs --all",
    "check:circular": "node scripts/check-circular-deps.mjs",
    "code:integration:check": "node scripts/code-integration-watch.mjs --fetch",
    "collab:status": "node scripts/collab-sync-loop.mjs --status-only --json",
    "collab:sync": "node scripts/collab-sync-loop.mjs",
    "collab:sync:fast": "node scripts/collab-sync-loop.mjs --validate-profile fast",
    "collab:sync:full": "node scripts/collab-sync-loop.mjs --validate-profile full",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "turbo run typecheck",
    "typecheck:affected": "node scripts/run-turbo-affected.mjs typecheck",
    "preflight:codex": "node scripts/check-repo-sot.mjs && node scripts/check-workflow-governance.mjs && pnpm check:workspace-task-coverage && node scripts/codex-preflight.mjs",
    "preflight:codex:ci": "pnpm check:workspace-task-coverage && node scripts/codex-preflight.mjs",
    "validate": "node scripts/validate.mjs",
    "validate:fast": "node scripts/validate.mjs --targeted-only --skip-typecheck",
    "validate:fast:e2e": "node scripts/validate.mjs --targeted-only --skip-typecheck --run-e2e",
    "validate:frontend-optimization": "pnpm -C apps/code build && pnpm check:code:bundle-budget -- --json && pnpm test:e2e:core",
    "validate:full": "node scripts/validate.mjs --full && node scripts/check-turbo-boundaries.mjs",
    "validate:release": "node scripts/validate-release.mjs",
    "integration:watch": "node scripts/integration-watch.mjs",
    "integration:watch:once": "node scripts/integration-watch.mjs --once",
    "prepare": "husky",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@playwright/mcp": "^0.0.68",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/vite-plugin": "^5.1.4",
    "@vitest/browser": "4.1.0",
    "@vitest/browser-playwright": "4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.2",
    "fast-check": "^4.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "lru-cache": "^11.2.6",
    "madge": "^8.0.0",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "rollup-preserve-directives": "^1.1.3",
    "tsx": "^4.21.0",
    "turbo": "^2.8.12",
    "typescript": "^5.9.3",
    "typescript-language-server": "^5.1.3",
    "vitest": "^4.1.0"
  },
  "config": {
    "repoBaselines": {
      "product": "HugeCode",
      "node": "22.21.1",
      "pnpm": "10.28.0",
      "rust": "1.93.1"
    }
  },
  "engines": {
    "node": ">=22.21.1 <23 || >=24 <25",
    "pnpm": "10.28.0"
  },
  "packageManager": "pnpm@10.28.0"
}
