{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/design-system/schemas/promotion-apply-report.schema.json",
  "type": "object",
  "required": [
    "artifactVersion",
    "generatedAt",
    "sourceManifest",
    "manifestRef",
    "applyRoot",
    "appliedTargets",
    "skippedTargets"
  ],
  "properties": {
    "artifactVersion": { "type": "integer", "minimum": 1 },
    "generatedAt": { "type": "string" },
    "sourceManifest": { "type": "string" },
    "manifestRef": { "type": "string" },
    "applyRoot": { "type": "string" },
    "appliedTargets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "componentName",
          "family",
          "targetLayer",
          "readiness",
          "approvalStatus",
          "appliedFiles",
          "overwrittenFiles",
          "notes"
        ],
        "properties": {
          "componentName": { "type": "string" },
          "family": { "type": "string" },
          "targetLayer": {
            "type": "string",
            "enum": [
              "design-system-primitive",
              "design-system-component",
              "app-adapter",
              "app-pattern",
              "defer"
            ]
          },
          "readiness": { "type": "string", "enum": ["ready", "review", "defer"] },
          "approvalStatus": { "type": "string", "enum": ["approved"] },
          "appliedFiles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["path", "role"],
              "properties": {
                "path": { "type": "string" },
                "role": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "overwrittenFiles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "skippedTargets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["componentName", "family", "reason"],
        "properties": {
          "componentName": { "type": "string" },
          "family": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
