{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "desktop-user-surfaces",
  "description": "User-triggered desktop surfaces for dialogs and external links.",
  "windows": ["main"],
  "permissions": [
    "dialog:allow-ask",
    "dialog:allow-message",
    "dialog:allow-open",
    "opener:allow-default-urls",
    "opener:allow-open-url",
    "opener:allow-reveal-item-in-dir"
  ]
}
