{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 100,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "es5",
  "semi": true,
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "ignorePatterns": [
    "node_modules",
    ".next",
    ".turbo",
    "**/dist",
    "**/*.d.ts",
    "**/*.d.ts.map",
    "packages/app/src/**/*.js",
    "packages/overlay/src/**/*.js",
    "coverage",
    "*.min.js",
    "**/*.min.js",
    "**/*.min.css",
    "apps/code/public/vendor",
    ".devcontainer/agents-skills",
    ".devcontainer/agents-skills/**",
    "**/routeTree.gen.ts",
    "**/*.inc",
    "pnpm-lock.yaml",
    "packages/mdvp-wasm/pkg",
    "artifacts/figma-codegen",
    "artifacts/figma-codegen/**",
    ".codex/figma-exports",
    ".codex/figma-exports/**",
    ".codex/figma-exports-validation",
    ".codex/figma-exports-validation/**"
  ]
}
