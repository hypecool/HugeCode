# x-router-rs runtime settings
X_ROUTER_HOST=0.0.0.0
X_ROUTER_PORT=4317
X_ROUTER_BASE_PATH=/v1/x-router
X_ROUTER_METRICS_PATH=/metrics

# Optional: auth
# X_ROUTER_AUTH_MODE=disabled
# X_ROUTER_API_KEYS=tenant-a=key-a|key-b,tenant-b=key-c

# Optional: upstream pool
# X_ROUTER_UPSTREAM_MODE=prefer-upstream
# X_ROUTER_UPSTREAMS=edge-a=http://127.0.0.1:4321,edge-b=http://127.0.0.1:4322
# X_ROUTER_UPSTREAM_TIMEOUT_MS=3000
# X_ROUTER_UPSTREAM_COOLDOWN_MS=15000
# X_ROUTER_UPSTREAM_MAX_ATTEMPTS=3
# X_ROUTER_UPSTREAM_MAX_IN_FLIGHT=256
# X_ROUTER_UPSTREAM_CIRCUIT_FAILURE_THRESHOLD=3
# X_ROUTER_UPSTREAM_CIRCUIT_OPEN_MS=20000
# X_ROUTER_UPSTREAM_RETRY_BUDGET_MAX_TOKENS=64
# X_ROUTER_UPSTREAM_RETRY_BUDGET_REFILL_PER_SUCCESS=0.25
# X_ROUTER_UPSTREAM_EWMA_ALPHA=0.2
# X_ROUTER_UPSTREAM_SELECTION=latency-aware

# Optional: tenant governance defaults
# X_ROUTER_TENANT_DEFAULT_RPM=1200
# X_ROUTER_TENANT_DEFAULT_BURST=600
# X_ROUTER_TENANT_DEFAULT_MAX_IN_FLIGHT=64
# X_ROUTER_TENANT_MAX_TRACKED=10000

# Optional: distributed limiter
# X_ROUTER_DISTRIBUTED_LIMITER_MODE=disabled
# X_ROUTER_DISTRIBUTED_LIMITER_REDIS_URL=redis://127.0.0.1:6379/0
# X_ROUTER_DISTRIBUTED_LIMITER_KEY_PREFIX=x-router
# X_ROUTER_DISTRIBUTED_LIMITER_FAIL_OPEN=true

# Optional: state persistence
# X_ROUTER_STATE_PERSISTENCE_PATH=.tmp/x-router-rs-state.json
# X_ROUTER_STATE_PERSISTENCE_AUTO_SAVE=true

# Optional: compatibility ingress
# X_ROUTER_COMPAT_ENABLED=false
# X_ROUTER_COMPAT_WS_ENABLED=true
# X_ROUTER_COMPAT_NOT_IMPLEMENTED_MODE=strict
# X_ROUTER_COMPAT_MODEL_CACHE_TTL_MS=15000
# X_ROUTER_COMPAT_MODEL_REFRESH_TIMEOUT_MS=2000
# X_ROUTER_COMPAT_MODEL_STATIC_JSON=
# X_ROUTER_COMPAT_MODEL_RATE_LIMIT_MODE=disabled
# X_ROUTER_COMPAT_MODEL_RATE_LIMIT_RPM=0
# X_ROUTER_COMPAT_MODEL_RATE_LIMIT_REDIS_URL=
# X_ROUTER_COMPAT_MODEL_RATE_LIMIT_REDIS_KEY_PREFIX=x-router:compat:model-rate
# X_ROUTER_COMPAT_MODEL_RATE_LIMIT_REDIS_TIMEOUT_MS=150
# X_ROUTER_COMPAT_SYSTEM_GUARD_ENABLED=true
# X_ROUTER_COMPAT_SYSTEM_MAX_IN_FLIGHT=2000
# X_ROUTER_COMPAT_SYSTEM_MAX_BODY_BYTES=10485760
# X_ROUTER_COMPAT_DECOMPRESS_ENABLED=true
# X_ROUTER_COMPAT_WS_MAX_CONNECTIONS=5000
# X_ROUTER_COMPAT_WS_IDLE_TIMEOUT_MS=60000
# X_ROUTER_COMPAT_WS_PING_INTERVAL_MS=15000
# X_ROUTER_COMPAT_WS_UPSTREAM_CONNECT_TIMEOUT_MS=5000
