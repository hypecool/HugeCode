{
  "name": "@ku0/discovery-rs",
  "version": "0.1.0",
  "description": "Rust mDNS discovery bindings for HypeCode.",
  "files": [
    "dist",
    "*.node"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/node.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "node": "./dist/node.js",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsx scripts/build-native.ts --release && tsc",
    "build:debug": "tsx scripts/build-native.ts && tsc",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix --fix-suggestions . && oxfmt --write ."
  },
  "dependencies": {
    "@ku0/native-bindings": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
