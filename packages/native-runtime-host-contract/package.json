{
  "name": "@ku0/native-runtime-host-contract",
  "version": "0.1.0",
  "private": true,
  "description": "Native Swift host contract types and method/event namespace helpers",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
