{
  "schemaVersion": 1,
  "datasetId": "runtime-provider-replay",
  "version": "2026-03-20",
  "description": "Managed replay dataset for runtime/provider-backed AI coding agent workflows. Sample files are the source of truth; runners compile temporary provider replay fixtures from this manifest.",
  "defaultRunner": "runtime-core-playwright",
  "redactionVersion": "runtime-provider-replay-v1",
  "runtimeIsolationDefault": {
    "strategy": "dedicated-runtime-port",
    "host": "127.0.0.1",
    "reuseExistingRuntime": false,
    "notes": "Replay and re-record flows allocate isolated runtime ports unless the caller explicitly opts into an existing runtime."
  },
  "taxonomy": [
    {
      "scenarioType": "read-only",
      "status": "implemented",
      "why": "Stable baseline for provider-backed analysis turns with minimal side effects."
    },
    {
      "scenarioType": "streaming-long-output",
      "status": "implemented",
      "why": "Exercises chunked provider output, multi-turn queueing, and long-response stability."
    },
    {
      "scenarioType": "tool-error-recovery",
      "status": "implemented",
      "why": "Validates that a failed runtime/provider turn is surfaced clearly and that the next turn can recover cleanly."
    },
    {
      "scenarioType": "runtime-isolation",
      "status": "implemented",
      "why": "Protects against accidental reuse of stale local runtimes and validates dedicated port binding."
    },
    {
      "scenarioType": "autodrive-launch",
      "status": "implemented",
      "why": "Captures runtime-only AutoDrive launch truth so decision, scenario, and autonomy state stay replay-visible."
    },
    {
      "scenarioType": "write-safe-minimal",
      "status": "implemented",
      "why": "Covers a deterministic low-risk write path so replay protects the smallest real workspace mutation workflow."
    },
    {
      "scenarioType": "unsupported-or-edge",
      "status": "implemented",
      "why": "Guards non-default and boundary behavior so regressions do not silently corrupt edge paths."
    }
  ],
  "admissionRules": {
    "golden": [
      "Recorded from a real runtime/provider path or migrated from an already verified golden sample.",
      "Schema-valid, replay-valid, and redaction-valid.",
      "Contains blocking assertions beyond final text equality.",
      "Stable under dedicated runtime isolation."
    ],
    "candidate": [
      "Useful scenario coverage but not yet stable enough for default CI.",
      "May require re-recording, broader normalization, or more resilient assertions."
    ],
    "archived": [
      "Kept for historical reference but excluded from default replay execution.",
      "Used when the workflow is obsolete, too flaky, or superseded by a better sample."
    ]
  },
  "coverageMatrix": {
    "sources": [
      "https://developers.openai.com/api/docs/guides/latest-model/",
      "https://developers.openai.com/api/docs/guides/evaluation-best-practices/"
    ],
    "modelProfiles": [
      {
        "id": "gpt-5.4",
        "modelId": "gpt-5.4",
        "family": "flagship",
        "coverageRole": "primary",
        "reasoningEffort": "low",
        "verbosity": "medium",
        "snapshotPinned": true,
        "status": "preferred",
        "notes": "Default flagship coverage track for the most important runtime replay workflows."
      },
      {
        "id": "gpt-5.1-codex-mini",
        "modelId": "gpt-5.1-codex-mini",
        "family": "mini",
        "coverageRole": "supporting",
        "reasoningEffort": "medium",
        "verbosity": "low",
        "snapshotPinned": true,
        "status": "active",
        "notes": "Cost-optimized model track kept in replay to catch routing and behavior drift."
      },
      {
        "id": "gpt-5.3-codex",
        "modelId": "gpt-5.3-codex",
        "family": "coding",
        "coverageRole": "compatibility",
        "reasoningEffort": "medium",
        "verbosity": "medium",
        "snapshotPinned": true,
        "status": "compatibility",
        "notes": "Compatibility coding-model route retained until a `gpt-5-codex` live sample is promoted into the replay golden set."
      }
    ],
    "capabilityCatalog": [
      {
        "id": "runtime-truth",
        "status": "implemented",
        "notes": "Structured runtime-published truth must be asserted independently from transcript equality."
      },
      {
        "id": "continuity-handoff",
        "status": "implemented",
        "notes": "Checkpoint, mission linkage, publish handoff, and review continuation truth."
      },
      {
        "id": "placement-routing",
        "status": "implemented",
        "notes": "Backend preference, routing choice, and operability metadata."
      },
      {
        "id": "autodrive-navigation",
        "status": "implemented",
        "notes": "AutoDrive decision trace and navigation-state coverage."
      },
      {
        "id": "autodrive-evaluation-profile",
        "status": "implemented",
        "notes": "Runtime evaluation profile and scenario-profile coverage for AutoDrive."
      },
      {
        "id": "event-replay-gap",
        "status": "implemented",
        "notes": "Replay gap resync and event durability assertions."
      },
      {
        "id": "tool-error-recovery",
        "status": "implemented",
        "notes": "Recoverable runtime/provider failure sequences with deterministic follow-up proof."
      },
      {
        "id": "write-safe",
        "status": "implemented",
        "notes": "Deterministic write-safe workspace mutations with machine-readable evidence."
      }
    ],
    "capabilityRequirements": [
      {
        "capabilityId": "runtime-truth",
        "requiredProfiles": ["gpt-5.4"],
        "notes": "Runtime truth migration starts with the flagship baseline before expanding to alternate tracks."
      },
      {
        "capabilityId": "tool-error-recovery",
        "requiredProfiles": ["gpt-5.4", "gpt-5.3-codex"],
        "notes": "Recovery coverage must keep both the flagship and compatibility coding route observable."
      },
      {
        "capabilityId": "write-safe",
        "requiredProfiles": ["gpt-5.4"],
        "notes": "Write-safe coverage stays anchored to the flagship route until additional migrated samples land."
      },
      {
        "capabilityId": "event-replay-gap",
        "requiredProfiles": ["gpt-5.4", "gpt-5.1-codex-mini", "gpt-5.3-codex"],
        "notes": "Replay gap resync assertions must stay live across flagship, mini, and compatibility coding routes."
      },
      {
        "capabilityId": "autodrive-navigation",
        "requiredProfiles": ["gpt-5.4", "gpt-5.3-codex"],
        "notes": "AutoDrive launch truth must stay visible on both the flagship and compatibility coding routes."
      },
      {
        "capabilityId": "autodrive-evaluation-profile",
        "requiredProfiles": ["gpt-5.4", "gpt-5.3-codex"],
        "notes": "Scenario and outcome coverage for AutoDrive launch must stay live on the flagship and compatibility coding routes."
      }
    ],
    "scenarioRequirements": [
      {
        "scenarioType": "read-only",
        "requiredProfiles": ["gpt-5.4", "gpt-5.3-codex"],
        "notes": "Read-only coverage must keep both flagship and coding-route inspection paths healthy."
      },
      {
        "scenarioType": "streaming-long-output",
        "requiredProfiles": ["gpt-5.4", "gpt-5.1-codex-mini"],
        "notes": "Streaming queue/resume coverage should prove both flagship and mini routing stay replay-safe."
      },
      {
        "scenarioType": "tool-error-recovery",
        "requiredProfiles": ["gpt-5.4", "gpt-5.3-codex"],
        "notes": "Recovery coverage spans the active flagship path and the coding-model route where failure behavior differs."
      },
      {
        "scenarioType": "runtime-isolation",
        "requiredProfiles": ["gpt-5.4", "gpt-5.1-codex-mini"],
        "notes": "Isolation checks must cover both the flagship default and the smaller mini tier."
      },
      {
        "scenarioType": "autodrive-launch",
        "requiredProfiles": ["gpt-5.4", "gpt-5.3-codex"],
        "notes": "AutoDrive launch truth is replayed on the flagship route and a compatibility coding route so the scenario is no longer single-sample thin."
      },
      {
        "scenarioType": "write-safe-minimal",
        "requiredProfiles": ["gpt-5.4"],
        "notes": "Safe write-path baseline remains anchored to the flagship route until mini write semantics are recorded."
      },
      {
        "scenarioType": "unsupported-or-edge",
        "requiredProfiles": ["gpt-5.3-codex", "gpt-5.1-codex-mini"],
        "notes": "Edge routing should exercise both legacy coding-model behavior and the smaller general route."
      }
    ]
  },
