{
  "name": "@ku0/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./styles/globals": {
      "types": "./src/styles/globals.ts",
      "default": "./dist/styles/globals.js"
    },
    "./styles/tokens": {
      "types": "./src/styles/tokens.ts",
      "default": "./dist/styles/tokens.js"
    }
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{ recursive: true, force: true })\" && vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint .",
    "test": "vitest run",
    "format": "oxfmt --write .",
    "clean": "node -e \"require('node:fs').rmSync('dist',{ recursive: true, force: true })\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@ku0/design-system": "workspace:*",
    "@ku0/shared": "workspace:*",
    "@vanilla-extract/css": "^1.18.0",
    "clsx": "^2.1.1",
    "lucide-react": "0.576.0",
    "next-themes": "^0.4.6"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "10.2.13",
    "@storybook/addon-docs": "10.2.13",
    "@storybook/react": "10.2.13",
    "@storybook/react-vite": "10.2.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/vite-plugin": "^5.1.4",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "10.0.2",
    "jsdom": "^28.1.0",
    "prettier": "3.8.1",
    "storybook": "10.2.13",
    "typescript": "5.9.3",
    "vite": "8.0.0",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
