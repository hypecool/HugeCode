{
  "$schema": "https://www.designtokens.org/TR/2025.10/format/",
  "$metadata": {
    "product": "HugeCode",
    "themes": ["light", "dark", "dim"]
  },
  "primitive": {
    "primitive": {
      "typography": {
        "family": {
          "ui": {
            "$type": "fontFamily",
            "$value": "\"Soehne\", \"Inter\", \"Manrope\", ui-sans-serif, system-ui, sans-serif"
          },
          "code": {
            "$type": "fontFamily",
            "$value": "\"IBM Plex Mono\", ui-monospace, monospace"
          }
        },
        "size": {
          "label": {
            "$type": "dimension",
            "$value": "14px"
          },
          "ui": {
            "$type": "dimension",
            "$value": "13px"
          },
          "content": {
            "$type": "dimension",
            "$value": "15px"
          },
          "title": {
            "$type": "dimension",
            "$value": "16px"
          },
          "display": {
            "$type": "dimension",
            "$value": "22px"
          }
        }
      }
    }
  },
  "semantic": {
    "common": {
      "space": {
        "2xs": {
          "$type": "dimension",
          "$value": "{primitive.space.2xs}"
        },
        "xs": {
          "$type": "dimension",
          "$value": "{primitive.space.xs}"
        },
        "sm": {
