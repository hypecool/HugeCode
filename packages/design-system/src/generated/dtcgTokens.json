        "xl": {
          "$type": "dimension",
          "$value": "{primitive.space.xl}"
        },
        "2xl": {
          "$type": "dimension",
          "$value": "{primitive.space.2xl}"
        }
      },
      "radius": {
        "sm": {
          "$type": "dimension",
          "$value": "{primitive.radius.sm}"
        },
        "md": {
          "$type": "dimension",
          "$value": "{primitive.radius.md}"
        },
        "lg": {
          "$type": "dimension",
          "$value": "{primitive.radius.lg}"
