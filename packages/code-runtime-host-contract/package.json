{
  "name": "@ku0/code-runtime-host-contract",
  "version": "0.1.0",
  "private": true,
  "description": "Transport-neutral contract types for runtime host request/response/event envelopes",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./codeRuntimeRpc": {
      "types": "./src/codeRuntimeRpc.ts",
      "default": "./src/codeRuntimeRpc.ts"
    },
    "./codeRuntimeRpcCompat": {
      "types": "./src/codeRuntimeRpcCompat.ts",
      "default": "./src/codeRuntimeRpcCompat.ts"
    },
    "./hugeCodeMissionControl": {
      "types": "./src/hugeCodeMissionControl.ts",
      "default": "./src/hugeCodeMissionControl.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run",
    "spec:generate": "tsx scripts/generate-runtime-rpc-spec.ts",
    "spec:check": "tsx scripts/check-runtime-rpc-spec.ts",
    "lint": "pnpm exec oxlint .",
    "lint:fix": "pnpm exec oxlint --fix --fix-suggestions . && pnpm exec oxfmt --write ."
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
